# ============================================================
# ALACRANES DE DURANGO — Variables de entorno
# ============================================================
# Copia este archivo como .env.local y rellena cada valor.
# NUNCA subas .env.local ni .env.production a git.
# ============================================================

# --- Supabase ---
# Obtén estos valores en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_XXXXXX
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXX

# IMPORTANTE: Esta clave es secreta. Solo se usa en el servidor.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...TU_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=sb_secret_XXXXXX

# --- PayPal Sandbox ---
# Obtén estas credenciales en: https://developer.paypal.com → Apps & Credentials → Sandbox
PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=TU_PAYPAL_CLIENT_SECRET
NEXT_PUBLIC_PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Para producción, usar:
# PAYPAL_BASE_URL=https://api-m.paypal.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
